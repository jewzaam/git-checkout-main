# Generated By: Cursor (claude-4-sonnet)
# Example GCM configuration file
# Copy to .gcm.yaml or ~/.gcm.yaml and customize
#
# GCM (Git Checkout Main) is a tool for managing git repositories with fork workflows.
# This configuration file controls how GCM behaves when setting up and managing your
# repository remotes and branches.

# Provider-specific settings for git hosting platforms
# Currently supports: github, gitlab
# username: Your username for authentication and fork operations
# fork_remote: Name of the git remote that points to your fork (created with -m flag)
providers:
  github:
    username: "your-github-username"
    fork_remote: "your-github-username"
  gitlab:
    username: "your-gitlab-username"
    fork_remote: "your-gitlab-username"

# Remote configuration
# upstream: Name of the upstream remote (usually "origin" or "upstream")
remotes:
  upstream: "origin"

# Branch configuration  


# Behavioral settings
# auto_create_forks: Automatically create fork remotes (true) or require -m flag (false)
# confirm_destructive: Prompt for confirmation before destructive operations
# parallel_operations: Perform operations in parallel for better performance
behavior:
  auto_create_forks: false
  confirm_destructive: true
  parallel_operations: true